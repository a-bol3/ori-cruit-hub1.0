# Core
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ori_cruit_hub

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth
JWT_SECRET=change_me_super_secret_for_dev
JWT_EXPIRES_IN=7d

# API
API_PORT=4000
API_BASE_URL=http://localhost:4000

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_CONVERSATIONS=candidate-conversations
MINIO_BUCKET_DOCUMENTS=candidate-documents
MINIO_BUCKET_SPREADSHEETS=spreadsheet-imports
MINIO_BUCKET_EXPORTS=exports
MINIO_USE_SSL=false

# OCR / AI
# OpenAI
OPENAI_API_KEY=
# Local OCR config if needed
OCR_PROVIDER=local 
LLM_PROVIDER=openai

# Caddy / Domain (Internal/Prod)
APP_DOMAIN=localhost
API_DOMAIN=localhost
